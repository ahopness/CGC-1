[node name="picth" parent="catalog/card_t/card/text" parent_id_path=PackedInt32Array(1029304753, 1870389204) index="0" unique_id=1906356846]
text = "A zero-player game where you make weapons and watch solders fight."

[node name="description" parent="catalog/card_t/card/text" parent_id_path=PackedInt32Array(1029304753, 1870389204) index="1" unique_id=1235295698]
text = "An anti-war zero-player simulation game where you engineer weapons and send off your pawns to the battlefield and watch them fight. You gain more resources each time your team wins a round. Good luck, you'll need it."

[node name="card_c" parent="catalog" unique_id=1935760614 instance=ExtResource("3_h2yge")]
visible = false
