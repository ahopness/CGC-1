[node name="picth" parent="catalog/card_n/card/text" parent_id_path=PackedInt32Array(833165612, 1870389204) index="0" unique_id=1906356846]
text = "Reverse hashing reconstruction software for mass storage segments."

[node name="description" parent="catalog/card_n/card/text" parent_id_path=PackedInt32Array(833165612, 1870389204) index="1" unique_id=1235295698]
text = "Recover and decrypt, sniff and scratch, this is - or was - a memoir. Most corrupted data here is encrypted, use reverse hashing techiniches to recontruct the echos of this single constant in this spiritual succesor to GIFT."

