anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 40.0
offset_top = 57.0
offset_right = -177.0
offset_bottom = -63.0
grow_horizontal = 2
grow_vertical = 2
text = "ABOUT
This is a collection of 5+1 games made between 2024 and 2026 , all of these titles contain experimental takes on different genres, from action to simulation, from horror to puzzle, dive into these wierd games, fall in love or hate every detail of the worlds and characters, no in-betweens, twee and brutal are the only available feelings here.

These titles are more akin to art pieces rathen than actual games, fun isn't garanteed. Everything is design with an intent in mind, but it's ok if you don't get it at first, neither do i most of the time, just try to feel it.

Something you wanna talk about? Hit me up at 'dev.lucas.angelo@gmail.com'.
Looking for more? Go check 'https://lucasangelo.dev' out.

KEYBOARD SHORTCUTS (Any Game)
[ESC] Quit
[F4] toggle fullscreen"
autowrap_mode = 2

