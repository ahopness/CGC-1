[node name="icon" parent="catalog/card_c/card" parent_id_path=PackedInt32Array(1935760614, 474488236) index="0" unique_id=132871009]
texture = ExtResource("6_ycdy4")

[node name="logo" parent="catalog/card_c/card" parent_id_path=PackedInt32Array(1935760614, 474488236) index="1" unique_id=1113418955]
texture = ExtResource("7_w48qg")

[node name="picth" parent="catalog/card_c/card/text" parent_id_path=PackedInt32Array(1935760614, 1870389204) index="0" unique_id=1906356846]
text = "Complex enemy AI inside a reality bending prison."

[node name="description" parent="catalog/card_c/card/text" parent_id_path=PackedInt32Array(1935760614, 1870389204) index="1" unique_id=1235295698]
text = "With controls that are out of the ordinary, the enemies also demonstrate complex behaviors that are only understood if you pay close attention to your surroundings. You can't make out if you're awake or still dreaming, reality is twisted around this far away prison with eyes around every corner and your biggest hope is to make it out in one peace."

[node name="card_f" parent="catalog" unique_id=1675244766 instance=ExtResource("3_h2yge")]
visible = false
layout_mode = 1

[node name="icon" parent="catalog/card_f/card" parent_id_path=PackedInt32Array(1675244766, 474488236) index="0" unique_id=132871009]
texture = ExtResource("8_vivmo")

[node name="logo" parent="catalog/card_f/card" parent_id_path=PackedInt32Array(1675244766, 474488236) index="1" unique_id=1113418955]
texture = ExtResource("9_2cqfq")

[node name="picth" parent="catalog/card_f/card/text" parent_id_path=PackedInt32Array(1675244766, 1870389204) index="0" unique_id=1906356846]
text = "Explore this surreal world, meet, greet & scream at it's residents."

[node name="description" parent="catalog/card_f/card/text" parent_id_path=PackedInt32Array(1675244766, 1870389204) index="1" unique_id=1235295698]
text = "Floating islands inside a virtual landscape, post-post-modern writing & retro visuals are all part of this part visual novel, part fps game. Dive in, walk, talk, scream. Gather points, but for what purpose? no one is really sure. Don't forget to beware, the horse is the white of the eye and the dark within. Eyes wide open."

