[node name="picth" parent="catalog/card_g/card/text" parent_id_path=PackedInt32Array(1054119299, 1870389204) index="0" unique_id=1906356846]
text = "You are on the post-death, search it, find memories, find yourself."

[node name="description" parent="catalog/card_g/card/text" parent_id_path=PackedInt32Array(1054119299, 1870389204) index="1" unique_id=1235295698]
text = "GIFT is about death and rebirth. Explore these liminal monochromatic fragments of memories, breath in that doubts that create fear, search it, find memories, find yourself. It's in our hands, everything is."

