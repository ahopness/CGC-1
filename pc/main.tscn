[node name="description" parent="catalog/card_b/card/text" parent_id_path=PackedInt32Array(474488236, 1870389204) index="1" unique_id=1235295698]
text = "Inside a depression in the middle of a desert, a blind soldier holds a special power: blood manipulation. Control, oppress and consume the blood of your enemies to win this arena amidst the world comes to an end."

